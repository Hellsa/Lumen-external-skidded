<Window x:Class="SkiddingApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Skidding" Height="550" Width="900"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" WindowStartupLocation="CenterScreen" 
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Window.Resources>
        <Storyboard x:Key="WindowLoad">
            <DoubleAnimation Storyboard.TargetName="RootBorder" Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.6"/>
            <DoubleAnimation Storyboard.TargetName="RootTransform" Storyboard.TargetProperty="Y" From="20" To="0" Duration="0:0:0.6">
                <DoubleAnimation.EasingFunction>
                    <ExponentialEase EasingMode="EaseOut" Exponent="10"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </Window.Resources>

    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard Storyboard="{StaticResource WindowLoad}"/>
        </EventTrigger>
    </Window.Triggers>
    
    <Border x:Name="RootBorder" Background="{StaticResource BackgroundBrush}" CornerRadius="12" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CacheMode="BitmapCache">
        <Border.RenderTransform>
            <TranslateTransform x:Name="RootTransform" Y="20"/>
        </Border.RenderTransform>
        <Grid TextElement.Foreground="White">
            <Grid.RowDefinitions>
                <RowDefinition Height="60"/> <!-- Top Nav -->
                <RowDefinition Height="*"/>   <!-- Content -->
            </Grid.RowDefinitions>

            <!-- Top Navigation -->
            <Grid Grid.Row="0" Margin="20,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- Logo -->
                    <Path Data="M12,2L4.5,20.29L5.21,21L12,18L18.79,21L19.5,20.29L12,2Z" Fill="{StaticResource AccentBrush}" Width="20" Height="20" Stretch="Uniform" Margin="0,0,10,0"/>
                    <StackPanel>
                        <TextBlock Text="SKIDDING" FontWeight="Bold" FontSize="14"/>
                        <TextBlock Text="v1.0.0" Foreground="{StaticResource SecondaryTextBrush}" FontSize="10"/>
                    </StackPanel>

                    <!-- Tabs -->
                    <StackPanel Orientation="Horizontal" Margin="40,0,0,0">
                        <RadioButton Style="{StaticResource NavButtonStyle}" Content="Home" IsChecked="True" Click="Tab_Click"/>
                        <RadioButton Style="{StaticResource NavButtonStyle}" Content="Players" Click="Tab_Click"/>
                        <RadioButton Style="{StaticResource NavButtonStyle}" Content="Visuals" Click="Tab_Click"/>
                        <RadioButton Style="{StaticResource NavButtonStyle}" Content="Aimbot" Click="Tab_Click"/>
                        <RadioButton Style="{StaticResource NavButtonStyle}" Content="Misc" Click="Tab_Click"/>
                        <RadioButton Style="{StaticResource NavButtonStyle}" Content="Settings" Click="Tab_Click"/>
                    </StackPanel>
                </StackPanel>

                <!-- Profile -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBlock Text="Olemad" VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="SemiBold"/>
                    <Path Data="M7,10L12,15L17,10H7Z" Fill="{StaticResource SecondaryTextBrush}" Width="12" Height="12" Stretch="Uniform"/>
                    <Button Content="✕" Foreground="White" Background="Transparent" BorderThickness="0" Margin="20,0,0,0" Click="Close_Click" Cursor="Hand"/>
                </StackPanel>
            </Grid>

            <!-- Content Area -->
            <Grid Grid.Row="1" Margin="30,10,30,30" x:Name="ContentHost">
                <Grid.RenderTransform>
                    <TranslateTransform X="0"/>
                </Grid.RenderTransform>
                
                <!-- HOME VIEW -->
                <Grid x:Name="HomeView" Visibility="Visible">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,10,0,25">
                        <TextBlock FontSize="28" FontWeight="Light">
                            <Run Text="Good afternoon, "/>
                            <Run Text="Olemad" FontWeight="SemiBold" FontStyle="Italic"/>
                        </TextBlock>
                        <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                            <TextBlock Text="Bring out greatness" Foreground="{StaticResource SecondaryTextBrush}" FontSize="12"/>
                            <TextBlock Text=" • " Foreground="{StaticResource SecondaryTextBrush}" VerticalAlignment="Center"/>
                            <TextBlock Text="5:33" Foreground="{StaticResource SecondaryTextBrush}" FontSize="12"/>
                        </StackPanel>
                    </StackPanel>

                    <UniformGrid Grid.Row="1" Columns="4" Margin="0,0,0,20">
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="CONNECTION" FontSize="10" Foreground="{StaticResource SecondaryTextBrush}" FontWeight="Bold" Margin="0,0,0,8"/>
                                <TextBlock x:Name="ConnectionStatus" Text="Idle" Foreground="#FFC107" FontSize="14" FontWeight="SemiBold"/>
                                <TextBlock x:Name="RobloxPID" Text="None" Foreground="{StaticResource SecondaryTextBrush}" FontSize="11" Margin="0,8,0,0"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="UPTIME" FontSize="10" Foreground="{StaticResource SecondaryTextBrush}" FontWeight="Bold" Margin="0,0,0,8"/>
                                <TextBlock x:Name="UptimeText" Text="00:00:00" FontSize="14" FontWeight="SemiBold"/>
                                <TextBlock Text="since launch" Foreground="{StaticResource SecondaryTextBrush}" FontSize="11" Margin="0,8,0,0"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="PLACE ID" FontSize="10" Foreground="{StaticResource SecondaryTextBrush}" FontWeight="Bold" Margin="0,0,0,8"/>
                                <TextBlock x:Name="PlaceIDText" Text="0" FontSize="14" FontWeight="SemiBold"/>
                                <TextBlock Text="live" Foreground="{StaticResource SecondaryTextBrush}" FontSize="11" Margin="0,8,0,0"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource CardStyle}" Margin="0">
                            <StackPanel>
                                <TextBlock Text="PLAYERS" FontSize="10" Foreground="{StaticResource SecondaryTextBrush}" FontWeight="Bold" Margin="0,0,0,8"/>
                                <TextBlock x:Name="PlayerCountText" Text="0" FontSize="14" FontWeight="SemiBold"/>
                                <TextBlock Text="in server" Foreground="{StaticResource SecondaryTextBrush}" FontSize="11" Margin="0,8,0,0"/>
                            </StackPanel>
                        </Border>
                    </UniformGrid>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Style="{StaticResource PanelStyle}" Margin="0,0,10,0">
                            <Grid>
                                <TextBlock Text="PLAYER ACTIVITY" FontSize="10" Foreground="{StaticResource SecondaryTextBrush}" FontWeight="Bold" Margin="15,15,0,0"/>
                                <Path Data="M 0,100 L 100,80 L 200,90 L 300,50 L 400,60" Stroke="White" StrokeThickness="1" Margin="15,40,15,15" Stretch="Fill" Opacity="0.3"/>
                            </Grid>
                        </Border>
                        <Border Grid.Column="1" Style="{StaticResource PanelStyle}" Margin="10,0,0,0">
                            <StackPanel Margin="15">
                                <TextBlock Text="NEARBY" FontSize="10" Foreground="{StaticResource SecondaryTextBrush}" FontWeight="Bold" Margin="0,0,0,15"/>
                                <ItemsControl x:Name="NearbyPlayersList">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,0,0,10">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold"/>
                                                    <TextBlock Text="{Binding AddressHex}" FontSize="9" Foreground="{StaticResource SecondaryTextBrush}" Opacity="0.6"/>
                                                </StackPanel>
                                                <TextBlock Text="{Binding Distance}" HorizontalAlignment="Right" VerticalAlignment="Center" Foreground="{StaticResource SecondaryTextBrush}"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>

                <!-- PLAYERS VIEW -->
                <Grid x:Name="PlayersView" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <!-- Table Headers -->
                    <Grid Grid.Row="0" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="0.5*"/>
                            <ColumnDefinition Width="100"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="PLAYER" Grid.Column="0" FontSize="10" Foreground="{StaticResource SecondaryTextBrush}" FontWeight="Bold"/>
                        <TextBlock Text="STATUS" Grid.Column="1" FontSize="10" Foreground="{StaticResource SecondaryTextBrush}" FontWeight="Bold"/>
                        <TextBlock Text="HEALTH" Grid.Column="2" FontSize="10" Foreground="{StaticResource SecondaryTextBrush}" FontWeight="Bold"/>
                        <TextBlock Text="DIST" Grid.Column="3" FontSize="10" Foreground="{StaticResource SecondaryTextBrush}" FontWeight="Bold"/>
                        <TextBlock Text="ACTIONS" Grid.Column="4" FontSize="10" Foreground="{StaticResource SecondaryTextBrush}" FontWeight="Bold" HorizontalAlignment="Right"/>
                    </Grid>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="PlayerListItems">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#0F0F0F" CornerRadius="8" Padding="15" Margin="0,0,0,10">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="2*"/>
                                                <ColumnDefinition Width="1*"/>
                                                <ColumnDefinition Width="2*"/>
                                                <ColumnDefinition Width="0.5*"/>
                                                <ColumnDefinition Width="100"/>
                                            </Grid.ColumnDefinitions>
                                            
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold"/>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding Name}" FontSize="10" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,0,5,0"/>
                                                    <TextBlock Text="{Binding UserId}" FontSize="10" Foreground="{StaticResource SecondaryTextBrush}" Opacity="0.7" Margin="0,0,5,0"/>
                                                    <TextBlock Text="|" FontSize="10" Foreground="{StaticResource SecondaryTextBrush}" Opacity="0.3" Margin="0,0,5,0"/>
                                                    <TextBlock Text="{Binding AddressHex}" FontSize="10" Foreground="{StaticResource AccentBrush}" Opacity="0.8"/>
                                                </StackPanel>
                                            </StackPanel>
                                            
                                            <Border Grid.Column="1" Background="#1A1A1A" CornerRadius="4" Padding="8,4" HorizontalAlignment="Left" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Status}" FontSize="11"/>
                                            </Border>
                                            
                                            <Grid Grid.Column="2" VerticalAlignment="Center" Margin="0,0,20,0">
                                                <ProgressBar Value="{Binding Health}" Maximum="{Binding MaxHealth}" Height="4" Background="#1A1A1A" Foreground="#4CAF50" BorderThickness="0"/>
                                                <TextBlock Text="{Binding HealthText}" FontSize="9" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,0,8"/>
                                            </Grid>
                                            
                                            <TextBlock Text="{Binding Distance}" Grid.Column="3" VerticalAlignment="Center" Foreground="{StaticResource SecondaryTextBrush}"/>
                                            
                                            <StackPanel Grid.Column="4" Orientation="Horizontal" HorizontalAlignment="Right">
                                                <Button Width="32" Height="32" Style="{StaticResource RoundButtonStyle}" Margin="0,0,5,0" Tag="{Binding Address, Mode=OneWay}" Click="Spectate_Click">
                                                    <Path Data="M12,9A3,3 0 0,0 9,12A3,3 0 0,0 12,15A3,3 0 0,0 15,12A3,3 0 0,0 12,9M12,4.5C7,4.5 2.73,7.61 1,12C2.73,16.39 7,19.5 12,19.5C17,19.5 21.27,16.39 23,12C21.27,7.61 17,4.5 12,4.5Z" Fill="White" Stretch="Uniform" Width="14" Height="14"/>
                                                </Button>
                                                <Button Width="32" Height="32" Style="{StaticResource RoundButtonStyle}" Tag="{Binding Address, Mode=OneWay}" Click="Teleport_Click">
                                                    <Path Data="M12,2C8.13,2 5,5.13 5,9C5,14.25 12,22 12,22C12,22 19,14.25 19,9C19,5.13 15.87,2 12,2M12,11.5A2.5,2.5 0 0,1 9.5,9A2.5,2.5 0 0,1 12,6.5A2.5,2.5 0 0,1 14.5,9A2.5,2.5 0 0,1 12,11.5Z" Fill="White" Stretch="Uniform" Width="14" Height="14"/>
                                                </Button>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>

                <!-- VISUALS VIEW -->
                <ScrollViewer x:Name="VisualsView" Visibility="Collapsed" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <!-- GENERAL -->
                        <TextBlock Text="GENERAL" FontSize="10" Foreground="{StaticResource SecondaryTextBrush}" FontWeight="Bold" Margin="0,0,0,10"/>
                        <Border Style="{StaticResource PanelStyle}" Padding="20" Margin="0,0,0,20">
                            <StackPanel>
                                <Grid Margin="0,0,0,15">
                                    <TextBlock Text="ESP Master" VerticalAlignment="Center"/>
                                    <CheckBox IsChecked="{Binding ESPMasterEnabled}" HorizontalAlignment="Right"/>
                                </Grid>
                                <Grid Margin="0,0,0,15">
                                    <TextBlock Text="Team Check" VerticalAlignment="Center"/>
                                    <CheckBox IsChecked="{Binding TeamCheckEnabled}" HorizontalAlignment="Right"/>
                                </Grid>
                                <Grid>
                                    <TextBlock Text="Knock Check" VerticalAlignment="Center"/>
                                    <CheckBox HorizontalAlignment="Right"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- FRIEND / ENEMY -->
                        <TextBlock Text="FRIEND / ENEMY" FontSize="10" Foreground="{StaticResource SecondaryTextBrush}" FontWeight="Bold" Margin="0,0,0,10"/>
                        <Border Style="{StaticResource PanelStyle}" Padding="20" Margin="0,0,0,20">
                            <StackPanel>
                                <Grid Margin="0,0,0,15">
                                    <TextBlock Text="Friend Color" VerticalAlignment="Center"/>
                                    <Border Width="16" Height="16" Background="#2196F3" CornerRadius="3" HorizontalAlignment="Right"/>
                                </Grid>
                                <Grid>
                                    <TextBlock Text="Enemy Color" VerticalAlignment="Center"/>
                                    <Border Width="16" Height="16" Background="#F44336" CornerRadius="3" HorizontalAlignment="Right"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- BOUNDING BOX -->
                        <TextBlock Text="BOUNDING BOX" FontSize="10" Foreground="{StaticResource SecondaryTextBrush}" FontWeight="Bold" Margin="0,0,0,10"/>
                        <Border Style="{StaticResource PanelStyle}" Padding="20" Margin="0,0,0,20">
                            <StackPanel>
                                <Grid Margin="0,0,0,15">
                                    <TextBlock Text="Box Enabled" VerticalAlignment="Center"/>
                                    <CheckBox IsChecked="{Binding BoxesEnabled}" HorizontalAlignment="Right"/>
                                </Grid>
                                <Grid Margin="0,0,0,15">
                                    <TextBlock Text="Fill Background" VerticalAlignment="Center"/>
                                    <CheckBox HorizontalAlignment="Right"/>
                                </Grid>
                                <Grid>
                                    <TextBlock Text="Box Style" VerticalAlignment="Center"/>
                                    <TextBlock Text="Full" HorizontalAlignment="Right" Foreground="{StaticResource SecondaryTextBrush}" FontStyle="Italic"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- HEALTH BAR -->
                        <TextBlock Text="HEALTH BAR" FontSize="10" Foreground="{StaticResource SecondaryTextBrush}" FontWeight="Bold" Margin="0,0,0,10"/>
                        <Border Style="{StaticResource PanelStyle}" Padding="20" Margin="0,0,0,20">
                            <StackPanel>
                                <Grid Margin="0,0,0,15">
                                    <TextBlock Text="Health Enabled" VerticalAlignment="Center"/>
                                    <CheckBox HorizontalAlignment="Right"/>
                                </Grid>
                                <Grid Margin="0,0,0,15">
                                    <TextBlock Text="High Health" VerticalAlignment="Center"/>
                                    <Border Width="16" Height="16" Background="#4CAF50" CornerRadius="3" HorizontalAlignment="Right"/>
                                </Grid>
                                <Grid>
                                    <TextBlock Text="Low Health" VerticalAlignment="Center"/>
                                    <Border Width="16" Height="16" Background="#F44336" CornerRadius="3" HorizontalAlignment="Right"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- PLAYER NAMES -->
                        <TextBlock Text="PLAYER NAMES" FontSize="10" Foreground="{StaticResource SecondaryTextBrush}" FontWeight="Bold" Margin="0,0,0,10"/>
                        <Border Style="{StaticResource PanelStyle}" Padding="20" Margin="0,0,0,20">
                            <StackPanel>
                                <Grid Margin="0,0,0,15">
                                    <TextBlock Text="Names Enabled" VerticalAlignment="Center"/>
                                    <CheckBox IsChecked="{Binding NamesEnabled}" HorizontalAlignment="Right"/>
                                </Grid>
                                <StackPanel Margin="0,0,0,15">
                                    <TextBlock Text="Name Type" FontSize="11" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,0,0,8"/>
                                    <Border Background="#1A1A1A" BorderBrush="#333333" BorderThickness="1" CornerRadius="6" Padding="12,8">
                                        <Grid>
                                            <TextBlock Text="Username" VerticalAlignment="Center"/>
                                            <Path Data="M7,10L12,15L17,10H7Z" Fill="{StaticResource SecondaryTextBrush}" Width="10" Height="10" Stretch="Uniform" HorizontalAlignment="Right"/>
                                        </Grid>
                                    </Border>
                                </StackPanel>
                                <Grid>
                                    <TextBlock Text="Name Color" VerticalAlignment="Center"/>
                                    <Border Width="16" Height="16" Background="White" CornerRadius="3" HorizontalAlignment="Right"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- DISTANCE -->
                        <TextBlock Text="DISTANCE" FontSize="10" Foreground="{StaticResource SecondaryTextBrush}" FontWeight="Bold" Margin="0,0,0,10"/>
                        <Border Style="{StaticResource PanelStyle}" Padding="20" Margin="0,0,0,20">
                            <StackPanel>
                                <Grid Margin="0,0,0,15">
                                    <TextBlock Text="Distance Enabled" VerticalAlignment="Center"/>
                                    <CheckBox IsChecked="{Binding DistanceEnabled}" HorizontalAlignment="Right"/>
                                </Grid>
                                <Grid>
                                    <TextBlock Text="Distance Color" VerticalAlignment="Center"/>
                                    <Border Width="16" Height="16" Background="#AAAAAA" CornerRadius="3" HorizontalAlignment="Right"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- LOOK DIRECTION -->
                        <TextBlock Text="LOOK DIRECTION" FontSize="10" Foreground="{StaticResource SecondaryTextBrush}" FontWeight="Bold" Margin="0,0,0,10"/>
                        <Border Style="{StaticResource PanelStyle}" Padding="20" Margin="0,0,0,20">
                            <StackPanel>
                                <Grid Margin="0,0,0,15">
                                    <TextBlock Text="Look Direction" VerticalAlignment="Center"/>
                                    <CheckBox HorizontalAlignment="Right"/>
                                </Grid>
                                <Grid>
                                    <TextBlock Text="Arrow Color" VerticalAlignment="Center"/>
                                    <Border Width="16" Height="16" Background="#2196F3" CornerRadius="3" HorizontalAlignment="Right"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- CHAMELEON -->
                        <TextBlock Text="CHAMELEON" FontSize="10" Foreground="{StaticResource SecondaryTextBrush}" FontWeight="Bold" Margin="0,0,0,10"/>
                        <Border Style="{StaticResource PanelStyle}" Padding="20">
                            <StackPanel>
                                <Grid Margin="0,0,0,15">
                                    <TextBlock Text="Chams Enabled" VerticalAlignment="Center"/>
                                    <CheckBox HorizontalAlignment="Right"/>
                                </Grid>
                                <Grid Margin="0,0,0,15">
                                    <TextBlock Text="Mesh Cache" VerticalAlignment="Center"/>
                                    <CheckBox HorizontalAlignment="Right"/>
                                </Grid>
                                <Grid>
                                    <TextBlock Text="Outline" VerticalAlignment="Center"/>
                                    <CheckBox HorizontalAlignment="Right"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Border>
</Window>
